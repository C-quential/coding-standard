{
  "name": "c-quential/coding-standard",
  "description": "C-quential Coding Standard for PHP_CodeSniffer.",
  "license": "MIT",
  "type": "phpcodesniffer-standard",
  "keywords": [ "phpcs" ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "require": {
    "php": "^8.3",
    "squizlabs/php_codesniffer": "^3.11.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.0.3"
  },
  "autoload": {
    "psr-4": {
      "CquentialCodingStandard\\": "CquentialCodingStandard/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "CquentialCodingStandard\\Tests\\": "tests/"
    }
  }
}